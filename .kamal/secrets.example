# Fetch secrets from Vaultwarden via Bitwarden CLI
# Copy this to .kamal/secrets and configure your Vaultwarden instance

# GHCR registry credentials
KAMAL_REGISTRY_USERNAME=$(kamal secrets fetch --adapter bitwarden --account vaultwarden GHCR_USERNAME)
KAMAL_REGISTRY_PASSWORD=$(kamal secrets fetch --adapter bitwarden --account vaultwarden GHCR_PAT)
